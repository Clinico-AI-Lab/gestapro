{
  "extends": "astro/tsconfigs/strict",
  "include": ["src", "scripts"],
  "exclude": ["dist", "node_modules", "_work"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "verbatimModuleSyntax": false
  }
}
