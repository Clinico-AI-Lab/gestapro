---
import LanguagesDonut from "./islands/LanguagesDonut.tsx";
interface Props { languages: Record<string, number>; }
const { languages } = Astro.props;
const empty = !languages || Object.keys(languages).length === 0;
---
<div class="donut-wrap">
  {empty ? <div class="empty-state tiny">No language data.</div> : <LanguagesDonut languages={languages} client:visible />}
</div>
