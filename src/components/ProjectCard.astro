---
import StatusBadge from "./StatusBadge.astro";
import Sparkline from "./Sparkline.astro";
import { relativeTime } from "~/lib/format";
interface Props {
  project: {
    slug: string;
    title: string;
    status: "active" | "paused" | "archived" | "planning";
    tags: string[];
    pushed_at: string | null;
    open_issues: number;
    open_prs: number;
    languages_top: string | null;
    headline_metric: { label: string; value?: number | string };
    sparkline_12w: number[];
    description: string;
  };
}
const { project } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<a href={`${base}/projects/${project.slug}`} class="project-card" style="text-decoration:none;">
  <div class="row row-between" style="align-items: flex-start;">
    <span class="title-link" style="display:block;">{project.title}</span>
    <StatusBadge status={project.status} />
  </div>
  <p class="muted tiny" style="margin: 0; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">{project.description}</p>
  <Sparkline values={project.sparkline_12w} />
  <div class="row tiny" style="gap: 0.75rem;">
    {project.languages_top && <span class="muted">● {project.languages_top}</span>}
    <span class="muted">{project.open_issues} issues · {project.open_prs} PRs</span>
    {project.pushed_at && <span class="dim">{relativeTime(project.pushed_at)}</span>}
  </div>
  {project.tags.length > 0 && (
    <div class="tags">
      {project.tags.slice(0, 4).map((t) => <span class="tag">{t}</span>)}
    </div>
  )}
  {project.headline_metric.value !== undefined && (
    <div class="tiny dim" style="margin-top: auto;">
      {project.headline_metric.label}: <strong style="color:var(--fg);">{project.headline_metric.value}</strong>
    </div>
  )}
</a>
